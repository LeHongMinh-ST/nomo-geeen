  FERTILIZER
  AGRI_MATERIAL
  CROP_SEED
  SEED
  SEEDLING
  VET_DRUG
  ANIMAL_FEED
  LIVESTOCK_SEED
  AQUA_DRUG
  AQUA_FEED
  AQUA_SEED
  OTHER
