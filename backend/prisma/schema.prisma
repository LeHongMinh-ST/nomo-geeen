// --- Master data ---

model Warehouse {
  id        String    @id @default(uuid())
  tenantId  String
  code      String    @default("DEFAULT")
  name      String
  isDefault Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stocks           Stock[]
  batches          ProductBatch[]
  movements        StockMovement[]
  purchases        Purchase[]
  sales            Sale[]
  salesReturns     SalesReturn[]
  stockAdjustments StockAdjustment[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("warehouse")
}

model DocumentSequence {
  id        String       @id @default(uuid())
  tenantId  String
  docType   DocumentType
  prefix    String?
  nextValue Int          @default(1)
  updatedAt DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, docType])
  @@map("document_sequence")
}

model Category {
  id        String      @id @default(uuid())
  tenantId  String
  name      String
  domain    AgriDomain?
  parentId  String?
  sortOrder Int         @default(0)
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([tenantId])
  @@map("category")
}

model Brand {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([tenantId])
  @@map("brand")
}

model Manufacturer {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([tenantId])
  @@map("manufacturer")
}

model Unit {
  id        String    @id @default(uuid())
  tenantId  String
  code      String
  name      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant      Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]
  conversions ProductUnitConversion[]
  saleLines   SaleLine[]
  purchaseLines PurchaseLine[]

  @@unique([tenantId, code])
  @@map("unit")
}

model Product {
  id               String        @id @default(uuid())
  tenantId         String
  sku              String
  barcode          String?
  name             String
  nameSearch       String?
  categoryId       String?
  brandId          String?
  manufacturerId   String?
  defaultSupplierId String?
  baseUnitId       String
  domain           AgriDomain?
  productKind      ProductKind   @default(OTHER)
  businessGroup    BusinessGroup?
  packSize         String?
  netContent       Decimal?      @db.Decimal(18, 6)
  netContentUnit   String?
  registrationNo   String?
  shortDesc        String?
  activeIngredient String?
  concentration    String?
  applyTargets     Json?
  pestTags         Json?
  attrs            Json?
  costPrice        BigInt        @default(0)
  salePrice        BigInt        @default(0)
  wholesalePrice   BigInt?
  isPinned         Boolean       @default(false)
  isLocked         Boolean       @default(false)
  isRecalled       Boolean       @default(false)
  status           ProductStatus @default(ACTIVE)
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand           Brand?                   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  manufacturer    Manufacturer?            @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  defaultSupplier Supplier?                @relation(fields: [defaultSupplierId], references: [id], onDelete: SetNull)
  baseUnit        Unit                     @relation(fields: [baseUnitId], references: [id])
  conversions     ProductUnitConversion[]
  priceTiers      ProductPriceTier[]
  customerPrices  CustomerProductPrice[]
  batches         ProductBatch[]
  stocks          Stock[]
  movements       StockMovement[]
  purchaseLines   PurchaseLine[]
  saleLines       SaleLine[]
  diseasePins     DiseaseProductPin[]
  diseaseFallbacksAsPrimary DiseaseProductFallback[] @relation("FallbackPrimary")
  diseaseFallbacksAsAlt     DiseaseProductFallback[] @relation("FallbackAlt")

  @@unique([tenantId, sku])
  @@index([tenantId, nameSearch])
  @@index([tenantId, barcode])
  @@index([tenantId, activeIngredient])
  @@index([tenantId, productKind])
  @@index([tenantId, businessGroup])
  @@index([tenantId, isPinned])
  @@map("product")
}

model TenantBusinessGroup {
  id            String        @id @default(uuid())
  tenantId      String
  businessGroup BusinessGroup
  enabled       Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, businessGroup])
  @@index([tenantId, enabled])
  @@map("tenant_business_group")
}

// Atomic tenant-scoped quota reservations. `periodKey = lifetime` is used for
// product counts; monthly dimensions can reuse this model later.
model TenantQuotaCounter {
  id         String   @id @default(uuid())
  tenantId   String
  dimension  String
  periodKey  String
  used       BigInt   @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dimension, periodKey])
  @@index([tenantId, dimension])
  @@map("tenant_quota_counter")
}

model ProductUnitConversion {
  id           String         @id @default(uuid())
  tenantId     String
  productId    String
  unitId       String
  factorToBase Decimal        @db.Decimal(18, 6)
  kind         ConversionKind @default(BOTH)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  unit    Unit    @relation(fields: [unitId], references: [id])

  @@unique([productId, unitId, kind])
  @@index([tenantId])
  @@map("product_unit_conversion")
}

model ProductPriceTier {
  id        String  @id @default(uuid())
  tenantId  String
  productId String
  minQty    Decimal @db.Decimal(18, 6)
  maxQty    Decimal? @db.Decimal(18, 6)
  price     BigInt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, productId])
  @@map("product_price_tier")
}

model CustomerProductPrice {
  id         String @id @default(uuid())
  tenantId   String
  customerId String
  productId  String
  price      BigInt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([tenantId])
  @@map("customer_product_price")
}

// --- Inventory ---

model ProductBatch {
  id             String    @id @default(uuid())
  tenantId       String
  productId      String
  warehouseId    String
  batchCode      String
  manufacturedAt DateTime? @db.Date
  expiresAt      DateTime? @db.Date
  isRecalled     Boolean   @default(false)
  qtyOnHand      Decimal   @default(0) @db.Decimal(18, 6)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  product       Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse     Warehouse        @relation(fields: [warehouseId], references: [id])
  movements     StockMovement[]
  purchaseLines PurchaseLine[]
  saleLines     SaleLine[]
  saleLineBatches SaleLineBatch[]

  @@unique([tenantId, productId, warehouseId, batchCode])
  @@index([expiresAt])
  @@index([isRecalled])
  @@map("product_batch")
}

model Stock {
  id          String  @id @default(uuid())
  tenantId    String
  warehouseId String
  productId   String
  qty         Decimal @default(0) @db.Decimal(18, 6)
  avgCost     BigInt  @default(0)
  updatedAt   DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([tenantId])
  @@map("stock")
}

model StockMovement {
  id          String         @id @default(uuid())
  tenantId    String
  warehouseId String
  productId   String
  batchId     String?
  direction   StockDirection
  qty         Decimal        @db.Decimal(18, 6)
  unitCost    BigInt?
  reason      StockReason
  refType     String
  refId       String
  refLineId   String?
  occurredAt  DateTime       @default(now())
  createdBy   String?
  note        String?
  createdAt   DateTime       @default(now())

  warehouse Warehouse    @relation(fields: [warehouseId], references: [id])
  product   Product      @relation(fields: [productId], references: [id])
  batch     ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([tenantId, productId, occurredAt])
  @@index([refType, refId])
  @@map("stock_movement")
}

model StockAdjustment {
  id          String   @id @default(uuid())
  tenantId    String
  docNo       String
  warehouseId String
  status      String   @default("COMPLETED")
  note        String?
  createdBy   String?
  createdAt   DateTime @default(now())

  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse              @relation(fields: [warehouseId], references: [id])
  lines     StockAdjustmentLine[]

  @@unique([tenantId, docNo])
  @@map("stock_adjustment")
}

model StockAdjustmentLine {
  id           String  @id @default(uuid())
  adjustmentId String
  productId    String
  batchId      String?
  qtyBefore    Decimal @db.Decimal(18, 6)
  qtyAfter     Decimal @db.Decimal(18, 6)
  delta        Decimal @db.Decimal(18, 6)

  adjustment StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)

  @@index([adjustmentId])
  @@map("stock_adjustment_line")
}

// --- Purchase ---

model Purchase {
  id              String         @id @default(uuid())
  tenantId        String
  docNo           String
  idempotencyKey  String?
  supplierId      String
  warehouseId     String
  status          PurchaseStatus @default(DRAFT)
  purchasedAt     DateTime       @default(now())
  subtotal        BigInt         @default(0)
  discountAmount  BigInt         @default(0)
  taxAmount       BigInt         @default(0)
  shippingFee     BigInt         @default(0)
  total           BigInt         @default(0)
  amountPaid      BigInt         @default(0)
  paymentMethod   String         @default("CASH")
  debtAmount      BigInt         @default(0)
  note            String?
  createdBy       String?
  completedAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier  Supplier       @relation(fields: [supplierId], references: [id])
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])
  lines     PurchaseLine[]
  vouchers  PaymentVoucher[]

  @@unique([tenantId, docNo])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, purchasedAt])
  @@map("purchase")
}

model PurchaseLine {
  id           String   @id @default(uuid())
  tenantId     String
  purchaseId   String
  productId    String
  unitId       String
  qty          Decimal  @db.Decimal(18, 6)
  qtyBase      Decimal  @db.Decimal(18, 6)
  unitPrice    BigInt
  lineDiscount BigInt   @default(0)
  lineTotal    BigInt
  batchCode    String?
  expiresAt    DateTime? @db.Date
  batchId      String?

  purchase Purchase     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product      @relation(fields: [productId], references: [id])
  unit     Unit         @relation(fields: [unitId], references: [id])
  batch    ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@index([tenantId])
  @@map("purchase_line")
}

// --- Sales ---

model Sale {
  id                    String       @id @default(uuid())
  tenantId              String
  docNo                 String
  channel               SaleChannel  @default(QUICK_SALE)
  status                SaleStatus   @default(COMPLETED)
  customerId            String?
  customerNameSnapshot  String?
  customerPhoneSnapshot String?
  warehouseId           String
  subtotal              BigInt       @default(0)
  discountAmount        BigInt       @default(0)
  taxAmount             BigInt       @default(0)
  total                 BigInt       @default(0)
  amountPaid            BigInt       @default(0)
  changeAmount          BigInt       @default(0)
  debtAmount            BigInt       @default(0)
  paymentMethod         PaymentMethod?
  soldAt                DateTime     @default(now())
  diseaseId             String?
  diseaseNameSnapshot   String?
  consultContext        Json?
  suggestedQtyMeta      Json?
  note                  String?
  idempotencyKey        String?
  createdBy             String?
  completedAt           DateTime?
  deletedAt             DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer  Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  disease   Disease?         @relation(fields: [diseaseId], references: [id], onDelete: SetNull)
  lines     SaleLine[]
  returns   SalesReturn[]
  vouchers  PaymentVoucher[]

  @@unique([tenantId, docNo])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, soldAt])
  @@index([tenantId, channel, status, soldAt])
  @@index([tenantId, customerId])
  @@map("sale")
}

model SaleLine {
  id                   String       @id @default(uuid())
  tenantId             String
  saleId               String
  productId            String
  productNameSnapshot  String
  unitId               String
  qty                  Decimal      @db.Decimal(18, 6)
  qtyBase              Decimal      @db.Decimal(18, 6)
  unitPrice            BigInt
  priceSource          PriceSource?
  lineDiscount         BigInt       @default(0)
  lineTotal            BigInt
  unitCost             BigInt       @default(0)
  batchId              String?

  sale    Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  unit    Unit            @relation(fields: [unitId], references: [id])
  batch   ProductBatch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)
  batches SaleLineBatch[]

  @@index([saleId])
  @@index([tenantId])
  @@map("sale_line")
}

model SaleLineBatch {
  id         String  @id @default(uuid())
  saleLineId String
  batchId    String
  qtyBase    Decimal @db.Decimal(18, 6)

  saleLine SaleLine     @relation(fields: [saleLineId], references: [id], onDelete: Cascade)
  batch    ProductBatch @relation(fields: [batchId], references: [id])

  @@index([saleLineId])
  @@map("sale_line_batch")
}

model SalesReturn {
  id             String     @id @default(uuid())
  tenantId       String
  docNo          String
  originalSaleId String?
  customerId     String?
  warehouseId    String
  status         SaleStatus @default(COMPLETED)
  total          BigInt     @default(0)
  debtAdjust     BigInt     @default(0)
  note           String?
  createdBy      String?
  completedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  originalSale Sale?              @relation(fields: [originalSaleId], references: [id], onDelete: SetNull)
  customer     Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id])
  lines        SalesReturnLine[]

  @@unique([tenantId, docNo])
  @@map("sales_return")
}

model SalesReturnLine {
  id            String  @id @default(uuid())
  salesReturnId String
  productId     String
  qtyBase       Decimal @db.Decimal(18, 6)
  lineTotal     BigInt  @default(0)

  salesReturn SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)

  @@index([salesReturnId])
  @@map("sales_return_line")
}

// --- Customer / Supplier ---

model Customer {
  id                 String        @id @default(uuid())
  tenantId           String
  code               String?
  name               String
  nameSearch         String?
  phone              String?
  address            String?
  type               CustomerType?
  productionProfile  Json?
  debtLimit          BigInt?
  openingBalance     BigInt        @default(0)
  balance            BigInt        @default(0)
  note               String?
  deletedAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales          Sale[]
  salesReturns   SalesReturn[]
  productPrices  CustomerProductPrice[]
  vouchers       PaymentVoucher[]

  @@index([tenantId, phone])
  @@index([tenantId, nameSearch])
  @@map("customer")
}

model Supplier {
  id              String         @id @default(uuid())
  tenantId        String
  code            String
  name            String
  supplierType    String?
  contactName     String?
  contactTitle    String?
  phone           String?
  email           String?
  address         String?
  taxCode         String?
  discountPercent Decimal?       @db.Decimal(8, 4)
  debtLimit       BigInt?
  paymentTerms    String?
  openingBalance  BigInt         @default(0)
  balance         BigInt         @default(0)
  status          SupplierStatus @default(ACTIVE)
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases       Purchase[]
  productsDefault Product[]
  vouchers        PaymentVoucher[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("supplier")
}

// --- Debt ---

model DebtLedger {
  id           String         @id @default(uuid())
  tenantId     String
  partyType    DebtPartyType
  partyId      String
  entryType    DebtEntryType
  direction    DebtDirection
  amount       BigInt
  balanceAfter BigInt?
  refType      String?
  refId        String?
  occurredAt   DateTime       @default(now())
  note         String?
  createdBy    String?
  createdAt    DateTime       @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, partyType, partyId, occurredAt])
  @@map("debt_ledger")
}

model PaymentVoucher {
  id             String        @id @default(uuid())
  tenantId       String
  docNo          String
  idempotencyKey String?
  voucherType    VoucherType
  partyType      DebtPartyType
  partyId        String
  amount         BigInt
  method         PaymentMethod @default(CASH)
  refSaleId      String?
  refPurchaseId  String?
  customerId     String?
  supplierId     String?
  occurredAt     DateTime      @default(now())
  note           String?
  createdBy      String?
  status         String        @default("COMPLETED")
  createdAt      DateTime      @default(now())

  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refSale  Sale?                 @relation(fields: [refSaleId], references: [id], onDelete: SetNull)
  refPurchase Purchase?          @relation(fields: [refPurchaseId], references: [id], onDelete: SetNull)
  customer Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  supplier Supplier?             @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  lines    PaymentVoucherLine[]

  @@unique([tenantId, docNo])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, occurredAt])
  @@map("payment_voucher")
}

model PaymentVoucherLine {
  id            String        @id @default(uuid())
  voucherId     String
  method        PaymentMethod
  amount        BigInt
  refSaleId     String?
  refPurchaseId String?

  voucher PaymentVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@map("payment_voucher_line")
}

// --- Handbook ---

model Disease {
  id            String       @id @default(uuid())
  tenantId      String
  name          String
  nameSearch    String?
  aliases       Json?
  aliasesSearch String?
  domain            AgriDomain        @default(GENERAL)
  /// Canonical Handbook category (five core + UNCATEGORIZED). Independent of product BusinessGroup.
  handbookCategory  HandbookCategory  @default(UNCATEGORIZED)
  target            String?
  type              DiseaseType?
  symptom           String?
  note              String?
  formulaExpr       String?
  isPinned          Boolean           @default(false)
  sortOrder         Int               @default(0)
  isActive          Boolean           @default(true)
  deletedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant      Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingredients DiseaseIngredient[]
  pins        DiseaseProductPin[]
  consultFields DiseaseConsultField[]
  fallbacks   DiseaseProductFallback[]
  sales       Sale[]

  @@index([tenantId, isPinned])
  @@index([tenantId, nameSearch])
  @@index([tenantId, handbookCategory])
  @@map("disease")
}

model DiseaseIngredient {
  id               String @id @default(uuid())
  tenantId         String
  diseaseId        String
  activeIngredient String
  sortOrder        Int    @default(0)

  disease Disease @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@index([diseaseId])
  @@map("disease_ingredient")
}

model DiseaseProductPin {
  id         String  @id @default(uuid())
  tenantId   String
  diseaseId  String
  productId  String
  sortOrder  Int     @default(0)
  isExcluded Boolean @default(false)

  disease Disease @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([diseaseId, productId])
  @@map("disease_product_pin")
}

model DiseaseConsultField {
  id        String           @id @default(uuid())
  tenantId  String
  diseaseId String?
  fieldKey  String
  label     String
  fieldType ConsultFieldType @default(NUMBER)
  unit      String?
  options   Json?
  required  Boolean          @default(false)
  sortOrder Int              @default(0)
  isEnabled Boolean          @default(true)

  disease Disease? @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@index([tenantId, diseaseId])
  @@map("disease_consult_field")
}

model DiseaseProductFallback {
  id                String @id @default(uuid())
  tenantId          String
  diseaseId         String
  primaryProductId  String
  fallbackProductId String
  sortOrder         Int    @default(0)

  disease         Disease @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  primaryProduct  Product @relation("FallbackPrimary", fields: [primaryProductId], references: [id], onDelete: Cascade)
  fallbackProduct Product @relation("FallbackAlt", fields: [fallbackProductId], references: [id], onDelete: Cascade)

  @@index([diseaseId, primaryProductId])
  @@map("disease_product_fallback")
}

// --- Settings ---

model TenantSettings {
  tenantId                   String  @id
  companyName                String?
  address                    String?
  phone                      String?
  email                      String?
  logoFileId                 String?
  currency                   String  @default("VND")
  timezone                   String  @default("Asia/Ho_Chi_Minh")
  language                   String  @default("vi")
  defaultPaymentMethod       PaymentMethod?
  receiptFooter              String?
  lowStockThresholdDefault   Decimal? @db.Decimal(18, 6)
  updatedAt                  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}
