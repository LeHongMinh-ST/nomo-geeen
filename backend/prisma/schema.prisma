// NomoGreen Retail Platform — Core SaaS / Admin schema (Phase 1)
// Ref: docs/base_spec.md (muc 3 + 19), docs/architecture.md
// Multi-tenant shared DB: bang nghiep vu co cot tenantId; bang platform khong loc theo tenant.
// Tien luu BigInt (VND, don vi nho nhat). Soft delete bang deletedAt.

generator client {
  provider = "prisma-client-js"
}

// Prisma 7: connection URL nam o prisma.config.ts (CLI) + driver adapter @prisma/adapter-pg (runtime).
datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum TenantType {
  HOUSEHOLD // nong ho (Simple Mode)
  RETAIL_DEALER // cua hang / dai ly nho le (Simple Mode)
  COOPERATIVE // hop tac xa (Advanced Mode)
  DISTRIBUTOR // nha phan phoi (Advanced, ngoai Phase 1)
  FARM // trang trai (Advanced, ngoai Phase 1)
}

enum TenantMode {
  SIMPLE // Phase 1
  ADVANCED // ngoai Phase 1
}

enum TenantStatus {
  ACTIVE
  SUSPENDED // tam khoa (vd het han, vi pham)
  LOCKED // khoa han (het trial khong gia han)
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING // dang dung thu (3.5)
  ACTIVE
  PAST_DUE // qua han thanh toan
  CANCELLED // huy chu dong
  EXPIRED // het han
}

enum InvoiceStatus {
  DRAFT
  ISSUED // da phat hanh, cho thanh toan
  PAID
  OVERDUE
  VOID // huy bo
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  QR
  MIXED // ban hang: nhieu phuong thuc
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PlatformAdminRole {
  SUPER_ADMIN // toan quyen van hanh SaaS
  SALER // ban B2C: tao tenant/user, seat, set MK
  SUPPORT // xu ly ticket, xem tenant
  BILLING // quan ly goi, hoa don, thanh toan
}

enum CreatedByType {
  PLATFORM_ADMIN
  USER
}

enum PlatformAdminStatus {
  ACTIVE
  DISABLED
}

enum UserStatus {
  ACTIVE
  INVITED // moi moi, chua kich hoat
  DISABLED
}

enum AnnouncementSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AnnouncementAudience {
  ALL_TENANTS
  SPECIFIC_TENANT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum AuditActorType {
  PLATFORM_ADMIN
  USER
  SYSTEM
}

// Audit action vocabulary (R6.5). 12 RBAC codes + 3 legacy for pre-existing
// LOGIN/LOGOUT/REFRESH_REUSE_DETECTED rows preserved by additive migration.
enum AuditAction {
  ADMIN_CREATE
  ADMIN_UPDATE
  ADMIN_DEACTIVATE
  ADMIN_REACTIVATE
  ADMIN_RESET_PASSWORD
  ADMIN_ROLE_ASSIGN
  ADMIN_ROLE_REVOKE
  ROLE_CREATE
  ROLE_UPDATE
  ROLE_DELETE
  ROLE_PERMISSION_GRANT
  ROLE_PERMISSION_REVOKE
  LOGIN
  LOGOUT
  REFRESH_REUSE_DETECTED
  // admin-tenant-management (deploy migration before app code that emits these)
  TENANT_UPDATE
  TENANT_STATUS_CHANGE
  TENANT_EXPORT
  // admin-tenant-provisioning (deploy migration before app code that emits these)
  TENANT_CREATE
  USER_CREATE
  USER_UPDATE
  USER_ROLE_CHANGE
  USER_DEACTIVATE
  USER_REACTIVATE
  USER_RESET_PASSWORD
  PLAN_CREATE
  PLAN_UPDATE
  PLAN_ACTIVATE
  PLAN_DEACTIVATE
  SUBSCRIPTION_ASSIGN
  SUBSCRIPTION_CHANGE
  SUBSCRIPTION_RENEW
  SUBSCRIPTION_CANCEL
}

enum NotificationType {
  DEBT_DUE // cong no den han
  LOW_STOCK // hang sap het
  NEAR_EXPIRED // hang sap het han
  SYSTEM // thong bao he thong / announcement
}

enum StoredFilePurpose {
  LOGO
  PRODUCT_IMAGE
  ATTACHMENT
}

enum AuthorType {
  PLATFORM_ADMIN
  USER
}

// ============================================================
// PLATFORM (khong scope theo tenant)
// ============================================================

// Moi khach hang dang ky tao ra 1 Tenant (3.1)
model Tenant {
  id         String       @id @default(uuid())
  slug       String       @unique // workspace slug: app.argonext.vn/<slug>
  name       String
  tenantType TenantType   @default(HOUSEHOLD)
  mode       TenantMode   @default(SIMPLE)
  status     TenantStatus @default(ACTIVE)
  logoUrl    String?
  seatBonus  Int          @default(0) // Admin/Saler cap them seat ngoai plan.maxUsers
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime? // soft delete (17)

  subscriptions  Subscription[]
  users          User[]
  roles          Role[]
  featureFlags   TenantFeatureFlag[]
  invoices       Invoice[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  storedFiles    StoredFile[]
  supportTickets SupportTicket[]
  announcements  SystemAnnouncement[] // announcement nham vao tenant nay
  // retail
  warehouses         Warehouse[]
  documentSequences  DocumentSequence[]
  categories         Category[]
  brands             Brand[]
  manufacturers      Manufacturer[]
  units              Unit[]
  products           Product[]
  customers          Customer[]
  suppliers          Supplier[]
  purchases          Purchase[]
  sales              Sale[]
  salesReturns       SalesReturn[]
  stockAdjustments   StockAdjustment[]
  debtLedgers        DebtLedger[]
  paymentVouchers    PaymentVoucher[]
  diseases           Disease[]
  tenantSettings     TenantSettings?
  quotaCounters      TenantQuotaCounter[]
  businessGroups     TenantBusinessGroup[]

  @@index([status])
  @@index([deletedAt])
  @@map("tenant")
}

// Goi dich vu (3.4): Starter / Professional / Enterprise
model Plan {
  id                 String       @id @default(uuid())
  code               String       @unique // starter | professional | enterprise
  name               String
  description        String?
  price              BigInt // VND theo chu ky
  billingCycle       BillingCycle @default(MONTHLY)
  maxUsers           Int // gioi han User (seat)
  maxWarehouses      Int          @default(1) // Phase 1: 1 kho
  maxProducts        Int?
  maxCustomers       Int?
  maxOrdersPerMonth  Int?
  maxStorageBytes    BigInt // gioi han Storage
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  features      PlanFeature[]
  subscriptions Subscription[]

  @@map("plan")
}

// Catalog capability (3.4, 3.9): sales_quick, debt, handbook, multi_user...
model Feature {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  group       String? // core | addon | advanced
  createdAt   DateTime @default(now())

  plans       PlanFeature[]
  tenantFlags TenantFeatureFlag[]

  @@map("feature")
}

// Join Plan <-> Feature: goi gom feature nao
model PlanFeature {
  id        String  @id @default(uuid())
  planId    String
  featureId String
  plan      Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([planId, featureId])
  @@index([featureId])
  @@map("plan_feature")
}

// Tenant <-> Plan (3.4, 3.5). Trial mo hinh bang status=TRIALING + trialEndsAt.
model Subscription {
  id           String             @id @default(uuid())
  tenantId     String
  planId       String
  status       SubscriptionStatus @default(TRIALING)
  billingCycle BillingCycle       @default(MONTHLY)
  startDate    DateTime           @default(now())
  endDate      DateTime? // moc het han chu ky hien tai
  trialEndsAt  DateTime? // 3.5: 7/15/30 ngay
  cancelledAt  DateTime?
  manualReference String? @db.VarChar(200)
  reason         String? @db.VarChar(500)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@index([tenantId, status, updatedAt])
  @@index([tenantId, status, startDate, endDate, trialEndsAt])
  @@map("subscription")
}

// Lich su billing (3.6). Khong phai ke toan.
model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  subscriptionId String?
  invoiceNumber  String        @unique
  amount         BigInt // VND
  status         InvoiceStatus @default(DRAFT)
  periodStart    DateTime?
  periodEnd      DateTime?
  issuedAt       DateTime?
  dueAt          DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  payments     Payment[]

  @@index([tenantId])
  @@index([status])
  @@map("invoice")
}

// Thanh toan cho invoice. Ho tro thanh toan nhieu lan (12).
model Payment {
  id        String        @id @default(uuid())
  invoiceId String
  amount    BigInt // VND
  method    PaymentMethod @default(BANK_TRANSFER)
  status    PaymentStatus @default(PENDING)
  reference String? // ma giao dich / noi dung chuyen khoan
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([status])
  @@map("payment")
}

// Nhan su van hanh SaaS (19). Tach khoi User cua tenant.
model PlatformAdmin {
  id                  String              @id @default(uuid())
  email               String              @unique
  passwordHash        String
  fullName            String
  role                PlatformAdminRole   @default(SUPPORT) // legacy enum; RBAC M:N qua AdminRoleAssignment
  status              PlatformAdminStatus @default(ACTIVE)
  mustChangePassword  Boolean             @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  announcements   SystemAnnouncement[]
  assignedTickets SupportTicket[]
  ticketMessages  TicketMessage[]
  roleAssignments AdminRoleAssignment[]

  @@map("platform_admin")
}

// M:N link table between PlatformAdmin and admin-side roles (R5/R8, F-02).
// onDelete: Cascade on admin (admin deletion cleans assignments); Restrict on role
// (admin endpoints must revoke/detach before role deletion).
model AdminRoleAssignment {
  id         String   @id @default(uuid())
  adminId    String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?

  admin PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)
  role  Role          @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([adminId, roleId])
  @@index([roleId])
  @@map("admin_role_assignment")
}

// Thong bao he thong (19). Nham toan bo tenant hoac 1 tenant cu the.
model SystemAnnouncement {
  id             String               @id @default(uuid())
  title          String
  body           String
  severity       AnnouncementSeverity @default(INFO)
  audience       AnnouncementAudience @default(ALL_TENANTS)
  targetTenantId String? // khi audience = SPECIFIC_TENANT
  createdById    String
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  targetTenant Tenant?       @relation(fields: [targetTenantId], references: [id], onDelete: SetNull)
  createdBy    PlatformAdmin @relation(fields: [createdById], references: [id])

  @@index([audience])
  @@index([targetTenantId])
  @@map("system_announcement")
}

// Support ticket (19). Nguoi tao la user cua tenant; nguoi xu ly la platform admin.
model SupportTicket {
  id           String         @id @default(uuid())
  tenantId     String
  subject      String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(NORMAL)
  createdById  String? // User cua tenant tao ticket
  assignedToId String? // PlatformAdmin xu ly
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo PlatformAdmin?  @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  messages   TicketMessage[]

  @@index([tenantId])
  @@index([status])
  @@map("support_ticket")
}

// Thread tra loi cua ticket. Author co the la admin hoac user.
model TicketMessage {
  id            String     @id @default(uuid())
  ticketId      String
  authorType    AuthorType
  authorAdminId String?
  authorUserId  String?
  body          String
  createdAt     DateTime   @default(now())

  ticket      SupportTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorAdmin PlatformAdmin? @relation(fields: [authorAdminId], references: [id], onDelete: SetNull)
  authorUser  User?          @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@map("ticket_message")
}

// ============================================================
// TENANT-SCOPED
// ============================================================

// Nguoi dung cua tenant (3.7, 3.8) — login: username | phone | email + password
model User {
  id                 String         @id @default(uuid())
  tenantId           String
  username           String
  email              String?
  phone              String?
  passwordHash       String
  mustChangePassword Boolean        @default(false)
  fullName           String
  roleId             String
  status             UserStatus     @default(ACTIVE)
  createdByType      CreatedByType?
  createdById        String?
  lastLoginAt        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime? // soft delete (17)

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role           Role            @relation(fields: [roleId], references: [id])
  createdTickets SupportTicket[]
  ticketMessages TicketMessage[]
  notifications  Notification[]

  @@unique([tenantId, username])
  @@index([tenantId, status])
  @@index([username])
  @@index([phone])
  @@index([email])
  @@map("user")
}

// Vai tro (3.8). tenantId null = system role. Phase 1: OWNER / MANAGER / STAFF.
// isAdmin: admin-side roles (SUPER_ADMIN/SALER/SUPPORT/BILLING).
model Role {
  id        String   @id @default(uuid())
  tenantId  String? // null = system role dung chung
  code      String // OWNER | MANAGER | STAFF | admin codes | Advanced...
  name      String
  isSystem  Boolean  @default(false)
  isAdmin   Boolean  @default(false)
  rank      Int? // 1=Owner 2=Manager 3=Staff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users            User[]
  permissions      RolePermission[]
  adminAssignments AdminRoleAssignment[]

  @@unique([tenantId, code])
  @@index([tenantId, isAdmin])
  @@map("role")
}

// Permission dang resource:action (architecture.md 6.2). vd: sales:create
// label/group/description: hien thi tieng Viet cho admin UI (R7.5+).
// group = resource (nhom theo resource); label la ten tieng Viet cua quyen.
model Permission {
  id          String   @id @default(uuid())
  code        String   @unique // resource:action
  resource    String // sales, product, inventory, report...
  action      String // view, create, edit, delete, approve, export
  group       String? // logical group (default = resource)
  label       String? // ten hien thi tieng Viet
  description String? // mo ta ngan tieng Viet
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@index([resource])
  @@index([group])
  @@map("permission")
}

// Join Role <-> Permission
model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permission")
}

// Override bat/tat module theo tenant (3.9). Ghi de PlanFeature.
model TenantFeatureFlag {
  id        String   @id @default(uuid())
  tenantId  String
  featureId String
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureId])
  @@index([tenantId])
  @@map("tenant_feature_flag")
}

// Audit Log (3.12, 18). Actor co the la admin, user, hoac system.
// actorRoleCode (R6.2): denormalized role code authorizing the action;
// nullable for SYSTEM actor or pre-migration rows. action (R6.5): enum
// enforced by R0-01 migration (legacy `String` rows CAST to enum).
model AuditLog {
  id             String         @id @default(uuid())
  tenantId       String? // null cho hanh dong cap platform
  actorType      AuditActorType @default(USER)
  actorId        String? // id cua PlatformAdmin/User
  actorRoleCode  String? // R6.2: role code dang authorize action
  action         AuditAction
  resource       String? // ten bang/module bi tac dong
  resourceId     String?
  before         Json?
  after          Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime       @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorType, actorId])
  @@map("audit_log")
}

// Thong bao (3.11). Scope theo tenant, co the nham 1 user cu the.
model Notification {
  id        String           @id @default(uuid())
  tenantId  String
  userId    String? // null = gui toan tenant
  type      NotificationType @default(SYSTEM)
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, readAt])
  @@map("notification")
}

// Metadata file tren R2/MinIO (3.10). BE chi luu metadata; sizeBytes phuc vu quota.
model StoredFile {
  id         String            @id @default(uuid())
  tenantId   String
  key        String            @unique // object key tren storage
  purpose    StoredFilePurpose @default(ATTACHMENT)
  fileName   String
  mimeType   String
  sizeBytes  BigInt
  uploadedBy String? // User id
  createdAt  DateTime          @default(now())
  deletedAt  DateTime? // soft delete (17)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, purpose])
  @@map("stored_file")
}

// ============================================================
// RETAIL — App cua hang (docs/database-design-retail.md v1.2)
// ============================================================

