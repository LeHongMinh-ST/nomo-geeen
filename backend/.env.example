# NomoGreen Backend — bien moi truong mau
# Copy sang .env va dien gia tri that. KHONG commit .env.

# PostgreSQL 16 (multi-tenant shared DB)
# Cong host 5434 (5432 thuong bi Postgres native/khac chiem tren may dev).
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/nomogreen?schema=public"

# Redis 7 (refresh token family + access token blacklist)
REDIS_URL="redis://localhost:6379"

# JWT — bi mat rieng cho access va refresh (KHONG dung chung). Dat gia tri that o .env.
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Cookie refresh token: Secure mac dinh true; prod se tu choi khoi dong neu false.
AUTH_COOKIE_SECURE="true"

# CORS: origin cua admin frontend (bat credentials cho cookie refresh).
CORS_ORIGIN="http://localhost:3000"

# Cong backend (ghim 3001 de tranh dung Next.js dev tren 3000).
PORT="3001"

# Bootstrap admin dau tien (seed). De trong de bo qua tao admin.
BOOTSTRAP_ADMIN_EMAIL=""
BOOTSTRAP_ADMIN_PASSWORD=""
