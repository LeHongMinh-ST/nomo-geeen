  "scope_lock": {
    "source": "Implement tenant purchase management so /nhap-hang stops using seed data and completing a purchase atomically increases stock, records stock movement, and updates supplier payable; /ton-kho must consume real inventory data.",
    "in_scope": [
      "Tenant-scoped purchase draft creation, listing, detail, completion, and cancellation rules in Simple Mode",
      "One default warehouse resolved server-side; no multi-warehouse selection or transfer",
      "Supplier CRUD and lookup needed by purchase flows, with tenant isolation and existing supplier permissions",
      "Purchase-unit to base-unit conversion using existing product conversion records and server-side validation",
      "Atomic Purchase/PurchaseLine, Stock, StockMovement, Supplier.balance, and supplier DebtLedger effects on completion",
      "Payment split between amountPaid and debtAmount, without standalone payment-voucher management",
      "Authenticated API clients and real data wiring for /nhap-hang and /ton-kho",
      "Backend, frontend, integration, E2E, rollback, authorization, and conversion acceptance verification"
    ],
    "out_of_scope": [
      "Purchase returns and supplier payment-voucher workflows",
      "Advanced purchase order, approval, receiving, or partial-receipt workflow",
      "Multi-warehouse selection, warehouse transfer, FIFO costing, or new batch-allocation policy",
      "Product CRUD, category CRUD, product conversion CRUD, or changes to sales behavior",
      "Offline persistence, receipt printing, tax/accounting integration, reporting/dashboard aggregation",
      "Import/export and bulk supplier migration"
    ],
    "expansion_policy": "requires-user-approval"
  },
