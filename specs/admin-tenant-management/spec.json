  "scope_lock": {
    "source": "Implement tenant management for platform administration, create and enforce the required permissions for each tenant-management operation.",
    "in_scope": [
      "Paginated and filtered tenant list for platform admins",
      "Tenant detail view with aggregate counts",
      "Edit tenant profile fields allowed by platform policy (name, tenantType, mode, logoUrl with HTTPS validation)",
      "Tenant lifecycle status transitions ACTIVE, SUSPENDED, LOCKED with atomic conditional update (metadata-only; no session/Redis enforcement)",
      "CSV export of tenant list subject to permission, formula-safe cells, and take:10001 bound",
      "Server-side permission enforcement using admin.tenant:view, admin.tenant:edit, admin.tenant:approve, admin.tenant:export",
      "Role grant matrix: SUPER_ADMIN bypass, SUPPORT all four admin.tenant:* codes, BILLING none",
      "Audit records via AuditLogger.run for tenant profile changes, lifecycle changes, and exports",
      "Admin frontend route /admin/cua-hang with permission-gated list, detail/edit, status actions, and export",
      "Optimistic concurrency on profile PATCH via expectedUpdatedAt",
      "Integration and negative-path verification against real Postgres, Redis, and the admin auth/RBAC foundation"
    ],
    "out_of_scope": [
      "Tenant self-registration or public onboarding",
      "Tenant user CRUD or tenant-scoped RBAC",
      "Subscription, billing, invoice, or payment management",
      "Tenant deletion or irreversible hard-delete",
      "Tenant impersonation",
      "Bulk status changes",
      "Custom permission creation",
      "Audit log viewer UI",
      "MFA, OAuth, or SSO",
      "Downstream status enforcement (session invalidation, Redis flush, tenant-API deny on SUSPENDED/LOCKED) — future tenant-status-enforcement spec",
      "JWT claim TTL/revocation policy (owned by admin-rbac-user-management)"
    ],
    "expansion_policy": "requires-user-approval"
  },
