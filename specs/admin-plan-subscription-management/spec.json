  "scope_lock": {
    "source": "Build Admin plan management and manual tenant subscription assignment, including backend feature/quota checks and audit history. Sales collects payment manually or coordinates manual transfer first; Stripe is deferred.",
    "in_scope": [
      "Admin CRUD and activation/deactivation for plans and their feature/quota definitions",
      "Admin view of a tenant's current subscription and subscription history",
      "Manual assign, change, renew, and cancel subscription operations",
      "Transactional audit history for every plan and subscription mutation",
      "Backend feature entitlement and quota enforcement primitives on tenant request paths",
      "Production tenant product read/write slice with atomic maxProducts quota counter",
      "Non-destructive downgrade behavior and tests for expiry, quota overflow, and plan change",
      "Admin UI for plan catalog and tenant subscription actions"
    ],
    "out_of_scope": [
      "Stripe or any automatic payment provider integration",
      "Automatic invoice generation, collection, retry, refund, or reconciliation",
      "Deleting or transforming tenant data during downgrade",
      "Tenant self-service billing portal",
      "Bulk plan changes and scheduled future plan changes",
      "A new audit-log viewer"
    ],
    "expansion_policy": "requires-user-approval"
  },
