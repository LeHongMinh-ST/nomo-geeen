  "scope_lock": {
    "source": "Implement đăng ký, auth, đăng nhập cho phía user; hoàn thiện tenant user session, frontend login và authorization theo các gap đã rà soát.",
    "in_scope": [
      "Public tenant registration creates one Tenant and its first OWNER user atomically, reusing the provisioning owner/role contract",
      "Tenant user login by username, phone, or email and password; the current user model assigns each user to exactly one tenant",
      "Short-lived tenant access JWT with tenantId, role, and permissions claims",
      "Rotating tenant refresh session in an HttpOnly cookie, logout, revocation, reuse detection, and /auth/me",
      "Tenant authorization guard and permission resolution that prevent cross-tenant access",
      "mustChangePassword first-login enforcement and authenticated password change",
      "Redis-backed login throttling/lockout and audit events for tenant auth lifecycle",
      "Frontend registration, login, session store, route guard, API refresh/retry, logout, and user-facing errors",
      "Backend unit/e2e and frontend build/reachability verification"
    ],
    "out_of_scope": [
      "SMS OTP, email verification, Google/Apple OAuth, MFA",
      "Forgot-password or unauthenticated password recovery",
      "Tenant self-service staff management and role administration",
      "Subscription assignment, billing, seat enforcement, or plan selection during registration",
      "Replacing admin authentication or changing the admin refresh-token contract",
      "Tenant-facing audit log UI",
      "Multiple tenant memberships per user and tenant-picker login flow; defer to a future phase"
    ],
    "expansion_policy": "requires-user-approval"
  },
  "dependencies": {
    "blockedBy": [
      "admin-tenant-provisioning"
    ],
