  "scope_lock": {
    "source": "Implement chức năng đăng nhập cho admin user, yêu cầu tuân thủ theo nguyên tắc refresh token, access_token (chỉ login cho admin)",
    "in_scope": [
      "PlatformAdmin email+password login (POST /auth/admin/login)",
      "JWT access token issuance & verification guard (~15m)",
      "Refresh token rotation with reuse detection (~30d) backed by Redis",
      "Logout & token revocation (Redis blacklist + family delete)",
      "GET /auth/me current-admin endpoint",
      "Argon2id password hashing",
      "Backend auth foundation (PrismaService, ConfigModule, RedisModule, cookie-parser, main.ts wiring, env vars, docker-compose redis)",
      "Bootstrap admin seed (env-driven initial SUPER_ADMIN)",
      "Frontend admin login form wiring to the real API",
      "Basic brute-force lockout + LOGIN/LOGOUT audit logs"
    ],
    "out_of_scope": [
      "Tenant User login",
      "Phone/OTP login",
      "Google/Apple OAuth",
      "Password reset / forgot password",
      "MFA",
      "Full resource:action RBAC enforcement beyond active-PlatformAdmin",
      "Tenant/Feature guards from the §6.2 chain"
    ],
    "expansion_policy": "requires-user-approval"
  },
