  "scope_lock": {
    "source": "Implement chức năng phân quyền, vai trò, quản lý admin user (cho phần quản trị)",
    "in_scope": [
      "Multi-role RBAC cho PlatformAdmin (admin có nhiều role, mỗi role có nhiều permission)",
      "CRUD PlatformAdmin (tạo, sửa, deactivate/reactivate, reset password) — chỉ SUPER_ADMIN",
      "CRUD Role + gán Permission cho Role (role editor) — chỉ SUPER_ADMIN",
      "Danh sách Permission (read-only, seed từ code taxonomy resource:action)",
      "Gán role cho admin (replace enum cũ PlatformAdminRole)",
      "Audit log cho mọi thao tác admin (CREATE/UPDATE/DELETE/ASSIGN_ROLE/REVOKE_ROLE/RESET_PASSWORD/STATUS_CHANGE)",
      "Permission guard @RequirePermission('resource:action') cho admin endpoints",
      "Wire Role/Permission tables vào AccessTokenClaims (role string → permission codes list)",
      "Frontend admin pages: /admin/nguoi-dung-quan-tri (admin list + create/edit), /admin/vai-tro (role list + editor), /admin/quyen-han (permission list)",
      "FE navigation/menu gating theo permission code",
      "Admin permission codes dùng prefix `admin.` (vd: `admin.user:view`) để tránh va chạm với 10 permission code tenant hiện có"
    ],
    "out_of_scope": [
      "RBAC cho Tenant User (User/Role gán cho tenant — out of scope cho spec này)",
      "Tenant-scoped permissions (chỉ platform-level)",
      "OAuth/SSO cho admin",
      "MFA/2FA",
      "Permission delegation / temporary permission grant",
      "Custom permission builder (admin tự tạo permission mới — read-only seed)",
      "Audit log viewer UI (ghi vào DB, query qua API endpoint riêng ở task khác)",
      "Self-service password change cho admin (chỉ reset bởi SUPER_ADMIN)",
      "audit_log.action enum chỉ giữ 12 code RBAC (R6.5) — code LOGIN/LOGOUT/REFRESH_REUSE_DETECTED hiện có do admin-authentication spec thêm vào, nằm ngoài scope cập nhật enum tại spec này"
    ],
    "expansion_policy": "requires-user-approval"
  },
