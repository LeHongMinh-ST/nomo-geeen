  "scope_lock": {
    "source": "Complete the existing tenant sales-order UI with real list, detail, create-draft, complete, and cancel APIs while synchronizing inventory and customer debt.",
    "in_scope": [
      "Tenant-scoped sales-order list and detail APIs wired to the existing /don-ban-hang screens",
      "Create sales orders as DRAFT or COMPLETED from the existing /don-ban-hang/tao form",
      "Complete a DRAFT order exactly once with atomic stock decrement, stock movement creation, and optional customer debt creation",
      "Cancel DRAFT and COMPLETED orders with lifecycle validation, atomic stock and debt compensation where applicable, and retry safety",
      "Search, status filtering, desktop pagination, and mobile incremental loading backed by the real API",
      "Tenant permissions, sales entitlement, idempotency or concurrency protection, negative-path coverage, and runtime reachability",
      "Responsive, accessible loading, empty, error, confirmation, and success states matching DESIGN.md"
    ],
    "out_of_scope": [
      "Sales returns",
      "Receipt printing or Zalo sharing",
      "Tax calculation",
      "Multi-warehouse selection or batch allocation",
      "Offline sales-order persistence or background synchronization",
      "Disease-consultation context and handbook integration",
      "Customer, product, or debt-management CRUD beyond consuming existing contracts",
      "Editing an existing draft after creation",
      "Reopening cancelled or completed orders"
    ],
    "expansion_policy": "requires-user-approval"
  },
