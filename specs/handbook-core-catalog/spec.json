  "scope_lock": {
    "source": "Expand the Handbook category spec into the five core business categories that drive Product, Inventory, Purchase, Sales, and domain-specific Handbook behavior. Each store may sell multiple categories or operate as a specialist store; the system must preserve category-specific attributes and workflows.",
    "in_scope": [
      "Five stable business groups: Thuốc bảo vệ thực vật + Phân bón, Cây giống, Thức ăn chăn nuôi, Thuốc thú y, Con giống",
      "Separate technical product kinds and validation inside each group, including PESTICIDE versus FERTILIZER and SEED versus SEEDLING where needed",
      "Common product contract plus category-specific attrs, units, prices, stock, lot/expiry/recall, and lifecycle rules",
      "Category-specific purchase, sale, return, adjustment, shrinkage, quarantine, and stock reporting behavior",
      "Handbook taxonomy and consultation context for crop, livestock, veterinary, feed, seedling, and livestock-seed use cases",
      "Tenant store configuration that enables one or more groups and supports specialist or mixed stores without deleting historical data",
      "Schema/API/UI/test design and implementation-ready task breakdown; no implementation code in this spec run"
    ],
    "out_of_scope": [
      "AI diagnosis, image recognition, external agronomic/legal registry integrations",
      "Native mobile application, offline-first inventory writes, multi-warehouse transfers",
      "Full veterinary medical record, animal production ERP, breeding/genetics management, or farm management",
      "Automatic regulatory compliance certification; fields are operational aids, not legal advice",
      "Marketplace, inter-store Handbook sharing, and advanced fallback recommendation engine"
    ],
    "expansion_policy": "requires-user-approval"
  },
