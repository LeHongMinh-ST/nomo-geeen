  "scope_lock": {
    "source": "Handbook five-category advice catalog aligned with core business catalog labels; not a re-implementation of product/inventory domains.",
    "in_scope": [
      "Five stable Handbook advice categories with exact Vietnamese labels and stable IDs",
      "Handbook entry filter/create/edit/search by category on /so-tay",
      "Tenant-scoped Disease/Handbook persistence and API validation for category",
      "Legacy AgriDomain mapping to UNCATEGORIZED without data loss",
      "Preserve recommendation ranking and technical disease fields",
      "Focused FE/BE tests and reachability for Handbook flows"
    ],
    "out_of_scope": [
      "Product BusinessGroup enablement and ProductKind attrs CRUD (core-catalog-foundation)",
      "Batch FEFO and purchase receiving (core-stock-lifecycle)",
      "Stock adjustment, returns, per-kind sale checkout PHI/REI/withdrawal",
      "AI diagnosis, image recognition, external agronomic/legal registries",
      "Native mobile, offline-first inventory, multi-warehouse transfers",
      "Full veterinary medical record or livestock ERP state machines",
      "Marketplace, inter-store Handbook sharing, advanced recommendation engine"
    ],
    "expansion_policy": "requires-user-approval"
  },
