# Chrome/Chromium Configuration
# ============================================================================

# Custom Chrome/Chromium executable path (optional)
# chrome-devtools auto-detects system Chrome at standard OS paths.
# Set this only if Chrome is installed in a non-standard location.
#
# macOS:
# CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#
# Windows:
# CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
#
# Linux:
# CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome

# Skip puppeteer's Chromium download during npm install (optional)
# Set to true if you already have Chrome/Chromium installed and want to skip
# the ~300MB Chromium download during `npm install`.
# PUPPETEER_SKIP_DOWNLOAD=true
